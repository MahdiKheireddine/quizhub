# ─── Django ─────────────────────────────────────────────
# In dev, leave this on the local module. On Render, set to
# config.django.production via the dashboard.
DJANGO_SETTINGS_MODULE=config.django.local

SECRET_KEY=replace-me-with-generated-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=

# Windows only — Linux/macOS leave unset (defaults to `npm` on PATH).
# NPM_BIN_PATH=C:\Program Files\nodejs\npm.cmd

# ─── Database ───────────────────────────────────────────
# In production set DATABASE_URL (host injects it).
# In dev, set the individual vars below.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_NAME=quizhub
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ─── Email (production only) ────────────────────────────
# Get an API key at https://app.brevo.com/settings/keys/api
# Free tier: 300 emails/day, no expiry.
ANYMAIL_BREVO_API_KEY=

# Must be a verified sender in Brevo (Senders & IPs → Domains)
DEFAULT_FROM_EMAIL=QuizHub <your-verified-sender@yourdomain.com>